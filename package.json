{
  "name": "extension-manager",
  "version": "1.1.0",
  "description": "Chrome 扩展管理器 + Sider 多模型 CLI/CDP/MCP 桥接工具",
  "private": true,
  "main": "cli.js",
  "bin": {
    "sider-ask": "./cli.js",
    "sider-cdp": "./cdp-client.js",
    "sider-mcp": "./sider-mcp-server.js"
  },
  "scripts": {
    "cli": "node cli.js",
    "cdp": "node cdp-client.js",
    "mcp": "node sider-mcp-server.js",
    "cdp-start": "bash cdp-start.sh"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": ["chrome-extension", "sider", "mcp", "cdp", "multi-model"],
  "author": "chong",
  "license": "MIT"
}
