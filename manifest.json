{
  "manifest_version": 3,
  "name": "扩展管理器",
  "version": "1.1.0",
  "description": "集中管理所有 Chrome 扩展 + CLI 桥接 Sider 多模型",
  "permissions": ["management", "storage", "tabs", "scripting", "alarms"],
  "host_permissions": ["https://sider.ai/*", "http://127.0.0.1:8766/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "扩展管理器"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
